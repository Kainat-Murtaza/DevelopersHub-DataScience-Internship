# Let's start by importing the tools we'll need for our analysis
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Setting up a clean, professional style for our visualizations
plt.style.use('seaborn-v0_8-darkgrid')
sns.set_palette("husl")

# Loading the classic Iris dataset 
from sklearn.datasets import load_iris
iris = load_iris()

# Converting the data into a pandas DataFrame for easier manipulation
df = pd.DataFrame(iris.data, columns=iris.feature_names)
df['species'] = iris.target
df['species'] = df['species'].map({0: 'setosa', 1: 'versicolor', 2: 'virginica'})

print("="*60)
print("Welcome to Task 1: Iris Dataset Analysis")
print("="*60)

# ============================================
# STEP 1: Getting to Know Our Data
# ============================================
print("\n 1. LET'S EXPLORE THE DATASET STRUCTURE:")
print(f"• The dataset contains {df.shape[0]} samples and {df.shape[1]} features")
print(f"• Features include: {', '.join(df.columns[:-1])}")
print(f"• Target variable: {df.columns[-1]} (3 species of iris flowers)")

print("\n Here's a sneak peek at the first few rows:")
print(df.head())

print("\n Quick statistical summary to understand our data's distribution:")
print(df.describe())

# Checking if we have any missing data to clean up
print("\n Checking for missing values:")
missing_values = df.isnull().sum()
if missing_values.sum() == 0:
    print(" Great news! No missing values found. The dataset is clean and ready for analysis.")
else:
    print(missing_values[missing_values > 0])

# ============================================
# STEP 2: Visualizing the Data
# ============================================
print("\n 2. CREATING VISUALIZATIONS TO UNDERSTAND PATTERNS:")

# Setting up a figure with multiple plots to tell the complete story
fig, axes = plt.subplots(2, 3, figsize=(15, 10))

# Scatter Plot 1: How do sepal dimensions relate across species?
sns.scatterplot(data=df, x='sepal length (cm)', y='sepal width (cm)', 
                hue='species', ax=axes[0,0])
axes[0,0].set_title('Relationship Between Sepal Length and Width', fontsize=12, fontweight='bold')
axes[0,0].set_xlabel('Sepal Length (cm)')
axes[0,0].set_ylabel('Sepal Width (cm)')

# Scatter Plot 2: Petal dimensions often tell us more about species differences
sns.scatterplot(data=df, x='petal length (cm)', y='petal width (cm)', 
                hue='species', ax=axes[0,1])
axes[0,1].set_title('Relationship Between Petal Length and Width', fontsize=12, fontweight='bold')
axes[0,1].set_xlabel('Petal Length (cm)')
axes[0,1].set_ylabel('Petal Width (cm)')

# Histograms: Understanding how each feature is distributed
features_to_plot = iris.feature_names
for i, feature in enumerate(features_to_plot):
    # Placing each histogram in the appropriate subplot
    if i == 0:
        ax = axes[0,2]
    elif i == 1:
        ax = axes[1,0]
    elif i == 2:
        ax = axes[1,1]
    else:
        ax = axes[1,2]
    
    sns.histplot(data=df, x=feature, hue='species', multiple="stack", ax=ax)
    ax.set_title(f'Distribution of {feature}', fontsize=11, fontweight='bold')
    ax.set_xlabel(feature.replace(' (cm)', '') + ' (cm)')
    ax.set_ylabel('Frequency')

# Box Plot: Spotting outliers across all features at once
sns.boxplot(data=df.drop('species', axis=1), ax=axes[1,2])
axes[1,2].set_title('Box Plot - Spotting Outliers Across Features', fontsize=12, fontweight='bold')
axes[1,2].tick_params(axis='x', rotation=45)

plt.tight_layout()
plt.savefig('iris_analysis_visualizations.png', dpi=300, bbox_inches='tight')
plt.show()
print(" Visualizations saved as 'iris_analysis_visualizations.png'")

# ============================================
# STEP 3: Understanding Feature Relationships
# ============================================
print("\n🔗 3. ANALYZING FEATURE CORRELATIONS:")

plt.figure(figsize=(10, 8))
correlation = df.drop('species', axis=1).corr()
sns.heatmap(correlation, annot=True, cmap='coolwarm', center=0, fmt='.2f', 
            square=True, linewidths=1)
plt.title('Feature Correlation Matrix\nHow Strongly Are Features Related?', 
          fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig('iris_correlation_matrix.png', dpi=300, bbox_inches='tight')
plt.show()
print(" Correlation matrix saved as 'iris_correlation_matrix.png'")

# ============================================
# STEP 4: Key Takeaways
# ============================================
print("\n 4. WHAT DID WE LEARN? KEY INSIGHTS:")
print("-" * 50)
print(" Setosa vs. Other Species:")
print("   • Setosa flowers have distinctly smaller petals compared to versicolor and virginica")
print("   • This makes petal measurements excellent predictors for species classification")

print("\n Strong Relationships:")
print("   • Petal length and width show a very strong correlation (0.96)")
print("   • This suggests we might only need one of these features for modeling")

print("\n Data Quality:")
print("   • The dataset is complete with no missing values - ready for modeling!")
print("   • All features follow roughly normal distributions with minimal outliers")
print("   • Measurements are consistent (all in centimeters)")

print("\n Business Value:")
print("   • Understanding these patterns helps build accurate species classification models")
print("   • Feature relationships guide us in selecting the right predictors")

print("\n" + "="*60)
print(" Task 1 Complete! Ready to move on to modeling.")
print("="*60)